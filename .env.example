# ════════════════════════════════════════════════════════════════
#  Nexus AI Agent OS — Environment Variables
#  cp .env.example .env  →  fill values  →  npm run server
#
#  Local dev:   Terminal 1: npm run dev    (Vite :3000)
#               Terminal 2: npm run server (Express :3002)
#  Docker:      docker-compose up --build
#  Tunnel:      tunnel.bat
# ════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────
SERVER_PORT=3002
APP_URL=http://localhost:3000

# ── Auth (REQUIRED) ───────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex

# ── AI Providers ──────────────────────────────────────────────────
# Free fallback always available via Pollinations (no key needed)
GEMINI_API_KEY=your_gemini_key_here
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
STABILITY_API_KEY=sk-...

# ── Database (optional — defaults to in-memory) ───────────────────
# PostgreSQL — enables persistent memory across restarts
POSTGRES_URL=postgresql://nexus:nexus_dev@localhost:5432/nexus
# Redis — enables Redis-backed memory and queues
REDIS_URL=redis://localhost:6379
# Docker Compose PostgreSQL password
POSTGRES_PASSWORD=nexus_dev

# ── Observability ────────────────────────────────────────────────
# Webhook for health alerts (Slack, Discord, PagerDuty webhook URL)
ALERT_WEBHOOK_URL=

# ── Feature Flags ────────────────────────────────────────────────
# Set true when running via Cloudflare/localtunnel to disable Vite HMR
DISABLE_HMR=false

# ── Monitoring ────────────────────────────────────────────────────
# Grafana dashboard credentials (docker-compose)
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me_in_production

# ── Deployment ────────────────────────────────────────────────────
# Public URL for the application
APP_URL=http://localhost:3000

# ── Production CORS ───────────────────────────────────────────────
# Set to your Netlify frontend URL so the backend allows cross-origin requests
# Example: https://nexus-ai-app.netlify.app
ALLOWED_ORIGIN=
